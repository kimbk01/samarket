# --- SAMarket 메신저 실서비스 운영 (복사 후 .env / 호스팅 시크릿에 반영) ---

# 공개 사이트 URL (선택) — 절대 링크·OAuth 리다이렉트 등에 사용
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (필수) — 서버 API·Realtime
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# 레이트 리밋 공유 (멀티 인스턴스 필수 권장)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# 메신저 준비 상태 API 보호 (선택) — 설정 시 헤더 x-messenger-readiness-secret 동일 값 필요
# MESSENGER_READINESS_SECRET=

# 체감 지연 튜닝 (선택, ms) — 트래픽 폭주 시 홈 디바운스만 소폭 올림
# NEXT_PUBLIC_MESSENGER_HOME_DEBOUNCE_MS=240
# NEXT_PUBLIC_MESSENGER_ROOM_META_DEBOUNCE_MS=200

# 배포 구간 (local | staging | production)
# NEXT_PUBLIC_APP_DEPLOY_TIER=production

# --- Web Push (VAPID) — 브라우저 푸시. `npm run generate:vapid` 로 키 생성
# WEB_PUSH_ENABLED=1
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   (클라이언트 구독용, 보통 VAPID_PUBLIC_KEY 와 동일)
# VAPID_SUBJECT=mailto:support@your-domain.com

# --- Capacitor 네이티브 셸 (선택) — `capacitor.config.ts` 의 `server.url`
# CAPACITOR_SERVER_URL=https://your-domain.com
